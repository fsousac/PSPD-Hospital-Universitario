# Template para o Secret hu-db-credentials. Copie para k8s/secrets.env
# (gitignored) e preencha com os valores reais do grupo 10 antes de rodar:
#
#   cp k8s/secrets.env.example k8s/secrets.env
#   # editar k8s/secrets.env com a senha real (123@g10)
#   kubectl create secret generic hu-db-credentials -n grupo-10 \
#     --from-env-file=k8s/secrets.env
#
# NUNCA commitar k8s/secrets.env com valores reais.

# Usado pelo authorization-service (Quarkus/JDBC) — usuário/senha em
# propriedades separadas, sem problema de encoding.
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://192.168.122.1:5432/pseudopep_g10
QUARKUS_DATASOURCE_USERNAME=grupo10_user
QUARKUS_DATASOURCE_PASSWORD=CHANGEME

# Usado pelo patient-data-service (SQLAlchemy/asyncpg) — senha precisa estar
# URL-encoded dentro da connection string. A senha real do grupo10 é
# "123@g10"; o "@" vira "%40" -> "123%40g10". Ajuste se a senha real for
# outra.
DATABASE_URL=postgresql+asyncpg://grupo10_user:CHANGEME_URLENCODED@192.168.122.1:5432/pseudopep_g10

# Usado pelo api-gateway para pseudonimizar patient_id na coorte anonimizada
# (HMAC-SHA256, ver internal/gateway/research.go). Precisa ter pelo menos 32
# bytes aleatórios — o gateway recusa iniciar se faltar ou for curta demais.
# Gerar com: openssl rand -hex 32
COHORT_PSEUDONYM_KEY=CHANGEME_RANDOM_32_BYTES_MIN
